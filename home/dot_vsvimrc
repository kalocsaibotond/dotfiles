" SOURCES:
" https://github.com/changemewtf/no_plugins
" https://github.com/YanivZalach/Vim_Config_NO_PLUGINS/tree/main

" Switching off Vi compatibility
set nocompatible

" Add numbers to the file.
set number relativenumber

" Set shift width to 4 spaces.Set tab width to 4 columns.
set shiftwidth=4
set tabstop=4

" While searching though a file incrementally highlight matching characters as you type.
set incsearch
set hlsearch

" Set the commands to save in history default number is 20.
set history=1000

" FINDING FILES:

" Search down into subfolders
" Provides tab-completion for all file-related tasks
set path+=**

" Setting shell preference
set shell=pwsh
set shellcmdflag=-NoLogo\ -ExecutionPolicy\ RemoteSigned\ -Command\ 
